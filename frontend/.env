# Set to 1 to use default HMR only (no automatic full page reload on every save).
# VITE_NO_FULL_RELOAD=1

# Phone / tablet on same Wi‑Fi: uncomment so Vite listens on LAN (http://YOUR_PC_IP:5173).
# VITE_DEV_LAN=1

# API origin (scheme + host only — no trailing /api). Paths in code already start with /api/.
# On http://localhost:5173 this is ignored; Vite proxies /api → Django :8001.
VITE_API_URL=https://dashboard.mmiraq.com
# Dev LAN backend (npm run dev → Django on port 8001): VITE_API_URL=http://192.168.1.3:8001

# Local storefront preview: http://127.0.0.1:5173/store/?shop_id=1
VITE_STOREFRONT_SHOP_ID=1
VITE_STOREFRONT_SHOP_NAME=MM IRAQ
