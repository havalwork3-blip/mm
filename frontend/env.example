# Set to 1 to use default HMR only (no automatic full page reload on every save).
# VITE_NO_FULL_RELOAD=1

# Optional. In dev, opening the app via a LAN IP (e.g. phone) auto-uses the same host on port 8000.
# Set this when the API is not on the same host:8000 (e.g. production or custom backend port).
# VITE_API_URL=https://api.example.com
