# Set to 1 to use default HMR only (no automatic full page reload on every save).
# VITE_NO_FULL_RELOAD=1

# Optional API origin (scheme + host, no path). Do NOT add /api — routes already use /api/…
# Wrong: VITE_API_URL=https://mmiraq.com/api   → requests become /api/api/users/me/
# Right: VITE_API_URL=https://mmiraq.com
# Dev LAN backend: VITE_API_URL=http://192.168.1.3:8000
# Production: VITE_API_URL=https://dashboard.mmiraq.com
