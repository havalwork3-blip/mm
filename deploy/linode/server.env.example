# Copy to backend/.env on the server and fill in real values.
# For HTTPS behind Nginx, set DJANGO_BEHIND_PROXY=1 (see config/settings.py).

DJANGO_DEBUG=false
SECRET_KEY=
ALLOWED_HOSTS=your.domain,www.your.domain
DATABASE_URL=postgresql://mnm_user:STRONG_PASSWORD@127.0.0.1:5432/mnm_db

# Must match the public URL users open in the browser (scheme + host, no path).
CORS_ALLOWED_ORIGINS=https://your.domain,https://www.your.domain
CSRF_TRUSTED_ORIGINS=https://your.domain,https://www.your.domain

DJANGO_BEHIND_PROXY=1
