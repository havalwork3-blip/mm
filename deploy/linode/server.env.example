# Copy to backend/.env on the server and fill in real values.
# For HTTPS behind Nginx, set DJANGO_BEHIND_PROXY=1 (see config/settings.py).

DJANGO_DEBUG=false
SECRET_KEY=
ALLOWED_HOSTS=dashboard.mmiraq.com,.mmiraq.com
DATABASE_URL=postgresql://mnm_user:STRONG_PASSWORD@127.0.0.1:5432/mnm_db

# Storefront subdomains call the dashboard API (see frontend getPublicApiBase).
# Option A — explicit origins:
# CORS_ALLOWED_ORIGINS=https://dashboard.mmiraq.com,https://mmch.mmiraq.com
# Option B — allow any origin (storefront uses unauthenticated fetch):
# CORS_ALLOW_ALL_ORIGINS=1
# Default when unset: CORS_ALLOWED_ORIGIN_REGEXES for https://*.mmiraq.com
CSRF_TRUSTED_ORIGINS=https://*.mmiraq.com,https://dashboard.mmiraq.com

DJANGO_BEHIND_PROXY=1

# Daily manager Telegram report (auto-send at configured time; Baghdad timezone).
MANAGER_TELEGRAM_SCHEDULER=1
DJANGO_BUSINESS_TZ=Asia/Baghdad
