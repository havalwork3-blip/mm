DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_USE_SQLITE=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.3
# LAN frontend URL (phone/tablet on same Wi‑Fi must use this origin):
DJANGO_DEV_FRONTEND_ORIGINS=http://192.168.1.3:5173

# Calendar ranges for sales/purchases/cashier use this timezone (default Iraq). Set to e.g. UTC if needed.
# DJANGO_BUSINESS_TZ=Asia/Baghdad

POSTGRES_DB=pos_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
