# Prefer SECRET_KEY / ALLOWED_HOSTS in production; DJANGO_* names remain supported.
SECRET_KEY=change-me
# DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
# For phone testing on the same Wi‑Fi, add your computer's LAN IP, e.g. 192.168.1.5
# ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.5
# Must match the Vite URL you open on the phone (scheme + host + port):
# DJANGO_DEV_FRONTEND_ORIGINS=http://192.168.1.5:5173

# Calendar ranges for sales/purchases/cashier use this timezone (default Iraq). Set to e.g. UTC if needed.
# DJANGO_BUSINESS_TZ=Asia/Baghdad

# PostgreSQL: use DATABASE_URL when possible (required when DJANGO_DEBUG=false and not SQLite).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Optional connection pool age in seconds (default 600).
# DATABASE_CONN_MAX_AGE=600

# Local/dev fallback when DATABASE_URL is unset and DJANGO_USE_SQLITE=false:
POSTGRES_DB=pos_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional: use SQLite instead of PostgreSQL (set true). Backup script still supports both.
# DJANGO_USE_SQLITE=false

# Production (DJANGO_DEBUG=false): tenant storefronts on *.mmiraq.com
# ALLOWED_HOSTS=dashboard.mmiraq.com,.mmiraq.com
# Default also appends DJANGO_EXTRA_ALLOWED_HOSTS (.mmiraq.com,dashboard.mmiraq.com).
# CORS: either list origins, or use defaults (regex for https://*.mmiraq.com):
# CORS_ALLOWED_ORIGINS=https://dashboard.mmiraq.com,https://mmch.mmiraq.com
# CORS_ALLOW_ALL_ORIGINS=1
# CSRF_TRUSTED_ORIGINS=https://*.mmiraq.com,https://dashboard.mmiraq.com

# Daily DB backup (Windows): from repo root run .\run-backup-daily.ps1 or schedule it in Task Scheduler.
